generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  clinic_id        String @id @default(cuid())
  clinic_name      String
  slug             String @unique
  clinic_location  String
  clinic_contactno String

  @@index([slug])
}
